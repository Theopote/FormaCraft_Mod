# Formacraft Python Backend — environment configuration
# Copy this file to .env and fill in your values.
# Without an API key, the backend uses rule-based fallback generation.

# --- LLM provider (optional) ---
# Most providers expose an OpenAI-compatible endpoint, so the backend talks to all of
# them through the OpenAI SDK + a base_url. Recognized provider ids:
#   Cloud : openai | deepseek | gemini | anthropic | openrouter | groq | mistral |
#           xai | together | moonshot | zhipu | qwen | siliconflow | openai_compat
#   Local : ollama | lmstudio | vllm | llamacpp   (no API key required)
#   auto  : backwards-compatible default
# Any unknown id is treated as openai_compat (works with any OpenAI-compatible API).
LLM_PROVIDER=auto

# --- OpenAI / OpenAI-compatible ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- DeepSeek ---
# DEEPSEEK_MODEL=deepseek-chat

# --- Local models (no API key needed) ---
# Ollama   : LLM_BASE_URL=http://localhost:11434/v1   (OLLAMA_MODEL=llama3.1)
# LM Studio: LLM_BASE_URL=http://127.0.0.1:1234/v1
# vLLM     : LLM_BASE_URL=http://localhost:8000/v1
# llama.cpp: LLM_BASE_URL=http://localhost:8080/v1
# OLLAMA_MODEL=llama3.1

# --- Default base URLs per provider (only needed to override the built-ins) ---
#   gemini      https://generativelanguage.googleapis.com/v1beta/openai
#   anthropic   https://api.anthropic.com/v1
#   openrouter  https://openrouter.ai/api/v1
#   groq        https://api.groq.com/openai/v1
#   mistral     https://api.mistral.ai/v1
#   xai         https://api.x.ai/v1
#   together    https://api.together.xyz/v1
#   moonshot    https://api.moonshot.cn/v1
#   zhipu       https://open.bigmodel.cn/api/paas/v4
#   qwen        https://dashscope.aliyuncs.com/compatible-mode/v1
#   siliconflow https://api.siliconflow.cn/v1
# LLM_BASE_URL=

# --- Model listing probe (Settings panel "refresh models" button) ---
# Hard timeout (seconds) for the backend's remote GET {base_url}/models probe.
# Raised from the old 2.5s so providers like DeepSeek don't false-fallback.
# MODELS_PROBE_TIMEOUT_SEC=8

# --- Timeouts (seconds, optional) ---
# LLM_CALL_TIMEOUT_SEC=45
# LLM_CALL_TIMEOUT_LLMPLAN_SEC=180

# --- LlmPlan response_format (optional) ---
# auto: try json_schema first, fall back to json_object if the provider rejects it
#       (in auto mode, providers known not to support strict json_schema — deepseek,
#        gemini, anthropic, mistral, xai, groq, together, moonshot, zhipu, qwen,
#        siliconflow, and all local providers — skip the json_schema attempt)
# on:   json_schema only (no fallback)
# off:  json_object only (legacy)
# LLMPLAN_JSON_SCHEMA=auto
# LLMPLAN_JSON_SCHEMA_STRICT=true

# --- LlmPlan latency governance (Phase 6, optional) ---
# Force a faster model for the llmplan step only (does not change the client's model).
# Handy for speed/quality comparison, e.g. gpt-4o-mini.
# LLMPLAN_MODEL=gpt-4o-mini

# --- Architecture reference web search (Phase 6, optional) ---
# Controls the (hidden) web search that used to add 3-8s to every generation.
# landmark: only search for real landmarks (Eiffel Tower / Forbidden City ...) — DEFAULT
# all:      search for landmarks AND generic styles (中式/欧式 ...) — old behavior, slower
# off:      never search
# ARCHITECTURE_SEARCH=landmark
# Hard timeout for the reference search; on timeout it is skipped, never blocking generation.
# ARCHITECTURE_SEARCH_TIMEOUT_SEC=3

# --- Web search provider (building research) ---
# Can also be set in-game: FormaCraft Settings → 搜索引擎
# auto | duckduckgo | bing | google_cse | tavily | serpapi | wikipedia_only
# SEARCH_PROVIDER=auto
# SEARCH_API_KEY=          # Bing or Google CSE key (or set in game settings)
# BING_SEARCH_API_KEY=
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_CX=           # Google Custom Search Engine ID
# TAVILY_API_KEY=
# SERPAPI_API_KEY=

# --- Optional: override archetype registry JSON path ---
# FORMACRAFT_ARCHETYPES_JSON=
