# Formacraft Python Backend — environment configuration
# Copy this file to .env and fill in your values.
# Without an API key, the backend uses rule-based fallback generation.

# --- LLM provider (optional) ---
# auto | openai | openai_compat | deepseek | ollama | openrouter | groq | together | lmstudio
LLM_PROVIDER=auto

# --- OpenAI / OpenAI-compatible ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- DeepSeek ---
# DEEPSEEK_MODEL=deepseek-chat

# --- Ollama (OpenAI-compatible endpoint) ---
# LLM_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1

# --- Timeouts (seconds, optional) ---
# LLM_CALL_TIMEOUT_SEC=45
# LLM_CALL_TIMEOUT_LLMPLAN_SEC=180

# --- LlmPlan response_format (optional) ---
# auto: try json_schema first, fall back to json_object if the provider rejects it
#       (in auto mode, providers known not to support strict json_schema — deepseek/
#        ollama/lmstudio — skip the json_schema attempt to avoid a wasted round-trip)
# on:   json_schema only (no fallback)
# off:  json_object only (legacy)
# LLMPLAN_JSON_SCHEMA=auto
# LLMPLAN_JSON_SCHEMA_STRICT=true

# --- LlmPlan latency governance (Phase 6, optional) ---
# Force a faster model for the llmplan step only (does not change the client's model).
# Handy for speed/quality comparison, e.g. gpt-4o-mini.
# LLMPLAN_MODEL=gpt-4o-mini

# --- Architecture reference web search (Phase 6, optional) ---
# Controls the (hidden) web search that used to add 3-8s to every generation.
# landmark: only search for real landmarks (Eiffel Tower / Forbidden City ...) — DEFAULT
# all:      search for landmarks AND generic styles (中式/欧式 ...) — old behavior, slower
# off:      never search
# ARCHITECTURE_SEARCH=landmark
# Hard timeout for the reference search; on timeout it is skipped, never blocking generation.
# ARCHITECTURE_SEARCH_TIMEOUT_SEC=3

# --- Optional: architecture research (Bing) ---
# BING_SEARCH_API_KEY=

# --- Optional: override archetype registry JSON path ---
# FORMACRAFT_ARCHETYPES_JSON=
