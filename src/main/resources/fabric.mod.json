{
  "schemaVersion": 1,
  "id": "formacraft",
  "version": "${version}",
  "name": "Formacraft",
  "description": "Semantic architecture compiler for Minecraft — AI-assisted building via natural language and spatial tools.",
  "authors": [
    "Theopote"
  ],
  "contact": {
    "homepage": "https://github.com/Theopote/FormaCraft_Mod",
    "sources": "https://github.com/Theopote/FormaCraft_Mod",
    "issues": "https://github.com/Theopote/FormaCraft_Mod/issues"
  },
  "license": "MIT",
  "icon": "assets/formacraft/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.formacraft.FormacraftMod"
    ],
    "client": [
      "com.formacraft.client.ClientInitializer"
    ],
    "formacraft_tools": [
      "com.formacraft.client.tool.BuiltinToolsEntrypoint"
    ],
    "server": [
      "com.formacraft.server.ServerInitializer"
    ],
    "fabric-datagen": [
      "com.formacraft.FormacraftDataGenerator"
    ]
  },
  "mixins": [
    "formacraft.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.17.3",
    "minecraft": "~1.21.10",
    "java": ">=21",
    "fabric-api": "*"
  }
}