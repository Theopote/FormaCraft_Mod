{
  "schemaVersion": 1,
  "id": "formacraft",
  "version": "${version}",
  "name": "Formacraft",
  "description": "A Minecraft mod for Formacraft",
  "authors": [
    "Your Name"
  ],
  "contact": {
    "homepage": "https://your-website.com/",
    "sources": "https://github.com/yourusername/formacraft"
  },
  "license": "CC0-1.0",
  "icon": "assets/formacraft/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.formacraft.FormacraftMod"
    ],
    "client": [
      "com.formacraft.client.ClientInitializer"
    ],
    "server": [
      "com.formacraft.server.ServerInitializer"
    ],
    "fabric-datagen": [
      "com.formacraft.FormacraftDataGenerator"
    ]
  },
  "mixins": [
    "formacraft.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.17.3",
    "minecraft": "~1.21.10",
    "java": ">=21",
    "fabric-api": "*"
  }
}